# Environment variables for CMDLM v2 training tooling.
# Copy to .env and fill in values, then: source .env
# (These are NOT used inside Docker — Docker gets env vars via run_docker_v2.sh)

# ── Telegram notifications (cluster_monitor.sh, haiku_log_analyst.py,
#    parse_training_trajectory.py) ─────────────────────────────────────────
# Get bot token from @BotFather on Telegram.
# Find chat ID by messaging @userinfobot.
BOT_TOKEN=your_bot_token_here
CHAT_ID=your_chat_id_here

# ── Claude API (haiku_log_analyst.py, training_mcp_server.py) ─────────────
# Required on the machine that runs haiku_log_analyst.py (cluster) and
# locally for the MCP server.
# Get from https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ── On the cluster, add these to ~/.telegram_credentials ──────────────────
# cluster_monitor.sh sources this file: source ~/.telegram_credentials
# File format:
#   export BOT_TOKEN="..."
#   export CHAT_ID="..."
# And add ANTHROPIC_API_KEY to ~/.bashrc or ~/.profile:
#   export ANTHROPIC_API_KEY="sk-ant-..."
